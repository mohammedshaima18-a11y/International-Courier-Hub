<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>
<?import javafx.geometry.Insets?>

<AnchorPane prefHeight="680" prefWidth="1024" xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.mycompany.internationalcourierhub1.gui.MainController"
            stylesheets="/css/styles.css">

    <!-- Header -->
    <HBox styleClass="header" prefHeight="55" AnchorPane.topAnchor="0"
          AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0">
        <padding><Insets left="20" right="20"/></padding>
        <VBox alignment="CENTER">
            <Label styleClass="header-title" text="International Courier Hub"/>
        </VBox>
        <Region HBox.hgrow="ALWAYS"/>
        <Label fx:id="statusLabel" styleClass="header-subtitle" translateY="3"/>
    </HBox>

    <!-- Sidebar Navigation -->
    <VBox styleClass="sidebar" spacing="2" AnchorPane.topAnchor="55"
          AnchorPane.leftAnchor="0" AnchorPane.bottomAnchor="0" prefWidth="220">
        <padding><Insets top="10" bottom="10"/></padding>

        <Button fx:id="navDashboard" styleClass="sidebar-btn,active" onAction="#showDashboard">
            <graphic><HBox spacing="10"><Label styleClass="sidebar-icon" text="📊"/><Label text="Dashboard"/></HBox></graphic>
        </Button>
        <Button fx:id="navCreate" styleClass="sidebar-btn" onAction="#showCreateShipment">
            <graphic><HBox spacing="10"><Label styleClass="sidebar-icon" text="📦"/><Label text="Create Shipment"/></HBox></graphic>
        </Button>
        <Button fx:id="navTrack" styleClass="sidebar-btn" onAction="#showTrackShipment">
            <graphic><HBox spacing="10"><Label styleClass="sidebar-icon" text="📍"/><Label text="Track Shipment"/></HBox></graphic>
        </Button>
        <Button fx:id="navCost" styleClass="sidebar-btn" onAction="#showCalculateCost">
            <graphic><HBox spacing="10"><Label styleClass="sidebar-icon" text="💰"/><Label text="Calculate Cost"/></HBox></graphic>
        </Button>
    </VBox>

    <!-- Content Area -->
    <StackPane styleClass="content-area" AnchorPane.topAnchor="55"
               AnchorPane.leftAnchor="220" AnchorPane.rightAnchor="0" AnchorPane.bottomAnchor="0">

        <!-- ============= DASHBOARD ============= -->
        <VBox fx:id="dashboardPanel" spacing="20" visible="true">
            <VBox spacing="5">
                <Label styleClass="card-title" text="Dashboard"/>
                <Label styleClass="card-subtitle" text="System overview and analytics"/>
            </VBox>

            <HBox spacing="15">
                <VBox styleClass="stat-card,stat-card-blue">
                    <Label styleClass="stat-label" text="Total Shipments"/>
                    <Label fx:id="totalShipmentsLabel" styleClass="stat-value" text="0"/>
                </VBox>
                <VBox styleClass="stat-card,stat-card-purple">
                    <Label styleClass="stat-label" text="Events Logged"/>
                    <Label fx:id="totalEventsLabel" styleClass="stat-value" text="0"/>
                </VBox>
                <VBox styleClass="stat-card,stat-card-teal">
                    <Label styleClass="stat-label" text="Trackings Active"/>
                    <Label fx:id="totalTrackingLabel" styleClass="stat-value" text="0"/>
                </VBox>
                <VBox styleClass="stat-card,stat-card-orange">
                    <Label styleClass="stat-label" text="System Status"/>
                    <Label fx:id="systemStatusLabel" styleClass="stat-value" text="✓"/>
                </VBox>
            </HBox>

            <VBox styleClass="content-card" spacing="12" VBox.vgrow="ALWAYS">
                <Label styleClass="card-title" text="System Report"/>
                <Label styleClass="card-subtitle" text="Click generate to view the latest report"/>
                <HBox spacing="10">
                    <Button fx:id="reportBtn" styleClass="btn-primary" text="Generate Report" onAction="#onReport"/>
                </HBox>
                <TextArea fx:id="reportArea" styleClass="text-area" editable="false"
                          VBox.vgrow="ALWAYS" prefRowCount="8" promptText="Report will appear here..."/>
            </VBox>
        </VBox>

        <!-- ============= CREATE SHIPMENT ============= -->
        <VBox fx:id="createPanel" spacing="20" visible="false">
            <VBox spacing="5">
                <Label styleClass="card-title" text="Create Shipment"/>
                <Label styleClass="card-subtitle" text="Register a new shipment in the system"/>
            </VBox>

            <VBox styleClass="content-card" spacing="15">
                <GridPane hgap="15" vgap="12">
                    <Label text="Type" styleClass="form-label" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                    <ComboBox fx:id="shipmentTypeCombo" GridPane.columnIndex="1" GridPane.rowIndex="0" prefWidth="300"/>

                    <Label text="Description" styleClass="form-label" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
                    <TextField fx:id="descriptionField" GridPane.columnIndex="1" GridPane.rowIndex="1" prefWidth="300" promptText="e.g. Electronics, Documents..."/>

                    <Label text="Weight (kg)" styleClass="form-label" GridPane.columnIndex="0" GridPane.rowIndex="2"/>
                    <TextField fx:id="weightField" GridPane.columnIndex="1" GridPane.rowIndex="2" prefWidth="300" promptText="e.g. 2.5"/>

                    <Label text="Destination" styleClass="form-label" GridPane.columnIndex="0" GridPane.rowIndex="3"/>
                    <TextField fx:id="destinationField" GridPane.columnIndex="1" GridPane.rowIndex="3" prefWidth="300" promptText="Required for International shipments"/>
                </GridPane>

                <HBox spacing="10">
                    <Button styleClass="btn-success" text="➕ Create Shipment" onAction="#onCreateShipment"/>
                    <Button styleClass="btn-warning" text="Clear Fields" onAction="#onClearShipment"/>
                </HBox>
            </VBox>

            <VBox styleClass="content-card" spacing="10" VBox.vgrow="ALWAYS">
                <Label styleClass="card-title" text="Activity Log"/>
                <TextArea fx:id="shipmentLogArea" styleClass="text-area" editable="false"
                          VBox.vgrow="ALWAYS" prefRowCount="6" promptText="Shipment creation log..."/>
            </VBox>
        </VBox>

        <!-- ============= TRACK SHIPMENT ============= -->
        <VBox fx:id="trackPanel" spacing="20" visible="false">
            <VBox spacing="5">
                <Label styleClass="card-title" text="Track Shipment"/>
                <Label styleClass="card-subtitle" text="Monitor shipments and notify customers"/>
            </VBox>

            <VBox styleClass="content-card" spacing="15">
                <GridPane hgap="15" vgap="12">
                    <Label text="Tracking ID" styleClass="form-label" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                    <TextField fx:id="trackingIdField" GridPane.columnIndex="1" GridPane.rowIndex="0" prefWidth="250" promptText="e.g. TRK-001"/>
                    <Button styleClass="btn-primary" text="➕ Add Tracking" onAction="#onAddTracking" GridPane.columnIndex="2" GridPane.rowIndex="0"/>

                    <Label text="Customer Name" styleClass="form-label" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
                    <TextField fx:id="customerNameField" GridPane.columnIndex="1" GridPane.rowIndex="1" prefWidth="250" promptText="e.g. Alice"/>
                    <Button styleClass="btn-success" text="🔔 Subscribe" onAction="#onSubscribe" GridPane.columnIndex="2" GridPane.rowIndex="1"/>

                    <Label text="New Status" styleClass="form-label" GridPane.columnIndex="0" GridPane.rowIndex="2"/>
                    <ComboBox fx:id="statusCombo" GridPane.columnIndex="1" GridPane.rowIndex="2" prefWidth="250"/>
                    <Button styleClass="btn-warning" text="🔄 Update Status" onAction="#onUpdateStatus" GridPane.columnIndex="2" GridPane.rowIndex="2"/>
                </GridPane>
            </VBox>

            <VBox styleClass="content-card" spacing="10" VBox.vgrow="ALWAYS">
                <Label styleClass="card-title" text="Tracking Log"/>
                <TextArea fx:id="trackingLogArea" styleClass="text-area" editable="false"
                          VBox.vgrow="ALWAYS" prefRowCount="6" promptText="Tracking notifications will appear here..."/>
            </VBox>
        </VBox>

        <!-- ============= CALCULATE COST ============= -->
        <VBox fx:id="costPanel" spacing="20" visible="false">
            <VBox spacing="5">
                <Label styleClass="card-title" text="Calculate Cost"/>
                <Label styleClass="card-subtitle" text="Estimate shipping costs using different strategies"/>
            </VBox>

            <VBox styleClass="content-card" spacing="15">
                <GridPane hgap="15" vgap="12">
                    <Label text="Weight (kg)" styleClass="form-label" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                    <TextField fx:id="costWeightField" GridPane.columnIndex="1" GridPane.rowIndex="0" prefWidth="300" promptText="e.g. 10"/>

                    <Label text="Distance (km)" styleClass="form-label" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
                    <TextField fx:id="costDistanceField" GridPane.columnIndex="1" GridPane.rowIndex="1" prefWidth="300" promptText="e.g. 1000"/>

                    <Label text="Strategy" styleClass="form-label" GridPane.columnIndex="0" GridPane.rowIndex="2"/>
                    <ComboBox fx:id="strategyCombo" GridPane.columnIndex="1" GridPane.rowIndex="2" prefWidth="300"/>
                </GridPane>

                <HBox spacing="10">
                    <Button styleClass="btn-primary" text="🧮 Calculate" onAction="#onCalculateCost"/>
                </HBox>

                <Label fx:id="costResultLabel" styleClass="result-label" text="Enter values and calculate"/>
            </VBox>

            <VBox styleClass="content-card" spacing="10" VBox.vgrow="ALWAYS">
                <Label styleClass="card-title" text="Calculation History"/>
                <TextArea fx:id="costLogArea" styleClass="text-area" editable="false"
                          VBox.vgrow="ALWAYS" prefRowCount="6" promptText="Cost calculations will appear here..."/>
            </VBox>
        </VBox>
    </StackPane>
</AnchorPane>
